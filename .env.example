# Salin ke `.env` lalu sesuaikan. Variabel berawalan VITE_ dibaca oleh Vite.

# Port server dev & preview frontend.
# Kosongkan (VITE_PORT=) untuk port dinamis (OS memilih port bebas otomatis).
VITE_PORT=5177

# Base URL backend API (Go).
VITE_API_BASE=http://localhost:8086

# metaapi service base (Meta Ads/WhatsApp/Instagram/Inbox).
VITE_META_API=http://localhost:8097
